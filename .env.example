# Postgres connection string (Neon or Supabase). Shared by the whole team.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# LLM runtime. OPENAI_BASE_URL is optional: point it at any OpenAI-compatible
# endpoint (Groq, Together, Ollama, vLLM) to use open-source models instead.
OPENAI_API_KEY=""
# OPENAI_BASE_URL="https://api.groq.com/openai/v1"

# Model overrides (defaults in lib/llm.ts). MODEL_SCORE must support `temperature`
# because the confidence bands come from 3x sampling at temp ~0.8.
# MODEL_EXTRACT="gpt-4.1-nano"
# MODEL_SCORE="gpt-4.1-mini"
# MODEL_HEAVY="gpt-4.1"

# Track A (data/ingestion)
GITHUB_TOKEN=""
ADAPTION_API_KEY=""
