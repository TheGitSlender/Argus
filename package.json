{
  "name": "argus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test:unit": "tsx scripts/test-unit.ts",
    "test:intel": "tsx --env-file=.env scripts/test-intel.ts",
    "test:pipeline": "tsx --env-file=.env scripts/test-pipeline.ts",
    "test:track-a": "tsx --test scripts/track-a/*.test.ts",
    "test:track-a:import": "tsx --env-file=.env scripts/track-a/import-corpus.ts --apply",
    "test:track-a:resolve": "tsx --env-file=.env scripts/track-a/entity-resolution.ts --apply",
    "test:track-a:extract": "tsx --env-file=.env scripts/track-a/claim-extraction.ts --apply --limit 1",
    "test:track-a:verify": "tsx --env-file=.env scripts/track-a/verify-handoff.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.16",
    "@prisma/client": "^6.19.3",
    "ai": "^7.0.31",
    "next": "16.2.10",
    "openai": "^6.48.0",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2",
    "tsx": "^4.23.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
